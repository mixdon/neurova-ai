# ─────────────────────────────────────────────────────────
# NEUROVA — Environment Variables
# Copy this file to .env.local and fill in your keys
# ─────────────────────────────────────────────────────────

# Option A: OpenRouter (recommended — access to GPT-4o, Claude, Mixtral, etc.)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Option B: Direct OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# Option C: Direct Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Site URL (used for OpenRouter referer header)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
